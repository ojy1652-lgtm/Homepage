---
interface TabItem {
  id: string;
  label: string;
  title: string;
  summary?: string;
  image?: string;
  meta?: string;
  Content: any;
}

interface Props {
  items: TabItem[];
  imageAltPrefix?: string;
}

const { items, imageAltPrefix = '' } = Astro.props;
const instanceId = `tabs-${Math.random().toString(36).slice(2)}`;
---

<div class="content-tabs" data-tabs-root>
  <div class="tab-list" role="tablist" aria-label="Content sections">
    {
      items.map((item, index) => (
        <button
          aria-controls={`${instanceId}-panel-${item.id}`}
          aria-selected={index === 0 ? 'true' : 'false'}
          class:list={['tab-button', index === 0 ? 'active' : '']}
          data-tab-button
          data-tab-target={`${instanceId}-panel-${item.id}`}
          id={`${instanceId}-tab-${item.id}`}
          role="tab"
          type="button"
        >
          {item.label}
        </button>
      ))
    }
  </div>

  <div class="tab-panels">
    {
      items.map((item, index) => {
        const PanelContent = item.Content;
        return (
          <article
            aria-labelledby={`${instanceId}-tab-${item.id}`}
            class:list={['tab-panel', index === 0 ? 'active' : '']}
            data-tab-panel
            hidden={index !== 0}
            id={`${instanceId}-panel-${item.id}`}
            role="tabpanel"
          >
            {item.image && <img class="panel-image" src={item.image} alt={`${imageAltPrefix}${item.title}`} />}
            <div class="panel-copy">
              {item.meta && <p class="meta">{item.meta}</p>}
              <h2>{item.title}</h2>
              {item.summary && <p class="summary">{item.summary}</p>}
              <div class="prose">
                <PanelContent />
              </div>
            </div>
          </article>
        );
      })
    }
  </div>
</div>

<script is:inline>
  document.querySelectorAll('[data-tabs-root]').forEach((root) => {
    const buttons = Array.from(root.querySelectorAll('[data-tab-button]'));
    const panels = Array.from(root.querySelectorAll('[data-tab-panel]'));

    const activate = (button) => {
      const targetId = button.getAttribute('data-tab-target');

      buttons.forEach((item) => {
        const selected = item === button;
        item.classList.toggle('active', selected);
        item.setAttribute('aria-selected', selected ? 'true' : 'false');
      });

      panels.forEach((panel) => {
        const selected = panel.id === targetId;
        panel.hidden = !selected;
        panel.classList.toggle('active', selected);
      });
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => activate(button));
      button.addEventListener('keydown', (event) => {
        const currentIndex = buttons.indexOf(button);
        const lastIndex = buttons.length - 1;
        let nextIndex = currentIndex;

        if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
          nextIndex = currentIndex === lastIndex ? 0 : currentIndex + 1;
        }

        if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
          nextIndex = currentIndex === 0 ? lastIndex : currentIndex - 1;
        }

        if (event.key === 'Home') {
          nextIndex = 0;
        }

        if (event.key === 'End') {
          nextIndex = lastIndex;
        }

        if (nextIndex !== currentIndex) {
          event.preventDefault();
          buttons[nextIndex].focus();
          activate(buttons[nextIndex]);
        }
      });
    });
  });
</script>

<style>
  .content-tabs {
    display: grid;
    gap: 28px;
  }

  .tab-list {
    display: grid;
    gap: 6px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .tab-button {
    align-items: center;
    background: #fff;
    border: 1px solid #c8d1d6;
    border-radius: 0;
    color: #152936;
    cursor: pointer;
    display: inline-flex;
    font: inherit;
    font-weight: 700;
    justify-content: center;
    min-height: 64px;
    padding: 12px 18px;
    text-align: center;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .tab-button:hover,
  .tab-button:focus-visible {
    border-color: var(--brand);
    outline: none;
  }

  .tab-button.active {
    background: #073b72;
    border-color: #073b72;
    color: #fff;
  }

  .tab-panels {
    border-top: 1px solid var(--line);
    padding-top: 30px;
  }

  .tab-panel {
    animation: panel-in 180ms ease;
    display: grid;
    gap: 30px;
    grid-template-columns: minmax(260px, 0.85fr) minmax(0, 1.15fr);
  }

  .tab-panel[hidden] {
    display: none;
  }

  .panel-image {
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .panel-copy {
    align-self: center;
  }

  .panel-copy h2 {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
  }

  .summary {
    color: var(--muted);
    font-size: 1.08rem;
    margin: 14px 0 20px;
  }

  @keyframes panel-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 820px) {
    .tab-list {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    }

    .tab-button {
      min-height: 56px;
      padding: 10px 12px;
    }

    .tab-panel {
      grid-template-columns: 1fr;
    }

    .panel-copy {
      align-self: start;
    }
  }
</style>
