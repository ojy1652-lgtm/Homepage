---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/research/', label: 'Research' },
  { href: '/publications/', label: 'Publications' },
  {
    href: '/people/',
    label: 'People',
    children: [
      { href: '/people/principal-investigator/', label: 'Principal Investigator' },
      { href: '/people/#researcher', label: 'Researcher' },
      { href: '/people/#alumni', label: 'Alumni' },
      { href: '/people/#collaborators', label: 'Collaborators' },
    ],
  },
  {
    href: '/facilities/',
    label: 'Facilities',
    children: [
      { href: '/facilities/#tem-fib', label: 'TEM & FIB' },
      { href: '/facilities/#in-situ-holder', label: 'In-situ holder' },
    ],
  },
  { href: '/news/', label: 'News' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="EM3 Home">
      <img class="brand-mark" src="/images/uploads/em3-logo.svg" alt="EM3" />
      <span class="brand-divider" aria-hidden="true"></span>
      <span class="brand-copy">
        <strong>Electron Microscopy <span>for</span></strong>
        <strong>Energy Materials <span>via</span></strong>
        <strong>Environment Manipulation</strong>
      </span>
    </a>
    <nav aria-label="Main navigation">
      {
        navItems.map((item) => (
          <div class:list={['nav-item', item.children ? 'has-dropdown' : '']}>
            <a
              href={item.href}
              class:list={[currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? 'active' : '']}
            >
              {item.label}
            </a>
            {
              item.children && (
                <div class="dropdown" aria-label={`${item.label} submenu`}>
                  {item.children.map((child) => (
                    <a href={child.href}>{child.label}</a>
                  ))}
                </div>
              )
            }
          </div>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: rgba(255, 255, 255, 0.94);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(12px);
  }

  .header-inner {
    align-items: center;
    display: flex;
    justify-content: space-between;
    min-height: 74px;
    gap: 22px;
  }

  .brand {
    align-items: center;
    display: flex;
    gap: 14px;
    min-width: 360px;
  }

  .brand-mark {
    height: 46px;
    object-fit: contain;
    width: auto;
  }

  .brand-divider {
    background: var(--line);
    display: block;
    height: 52px;
    width: 1px;
  }

  .brand-copy {
    display: grid;
    gap: 1px;
    line-height: 1.12;
  }

  .brand-copy strong {
    color: var(--brand);
    display: block;
    font-size: clamp(0.88rem, 1.25vw, 1.08rem);
    font-weight: 700;
    white-space: nowrap;
  }

  .brand-copy span {
    color: var(--ink);
    font-size: 0.72em;
    font-weight: 500;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    justify-content: flex-end;
  }

  .nav-item {
    position: relative;
  }

  .has-dropdown::after {
    content: "";
    height: 12px;
    left: 0;
    position: absolute;
    right: 0;
    top: 100%;
  }

  nav a {
    border-radius: 6px;
    color: var(--muted);
    display: inline-flex;
    font-size: 0.94rem;
    font-weight: 700;
    padding: 9px 11px;
  }

  nav a.active,
  nav a:hover {
    background: #f1f6fb;
    color: var(--brand);
  }

  .dropdown {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 18px 38px rgba(23, 36, 45, 0.14);
    display: grid;
    gap: 2px;
    left: 0;
    min-width: 230px;
    opacity: 0;
    padding: 8px;
    pointer-events: none;
    position: absolute;
    top: calc(100% + 6px);
    transform: translateY(4px);
    transition:
      opacity 150ms ease,
      transform 150ms ease;
    z-index: 30;
  }

  .dropdown a {
    border-radius: 6px;
    color: var(--ink);
    justify-content: flex-start;
    padding: 10px 12px;
    white-space: nowrap;
    width: 100%;
  }

  .dropdown a:hover,
  .dropdown a:focus-visible {
    background: #f1f6fb;
    color: var(--brand);
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  @media (max-width: 760px) {
    .header-inner {
      align-items: flex-start;
      flex-direction: column;
      padding: 14px 0;
    }

    nav {
      justify-content: flex-start;
    }

    .brand {
      min-width: 0;
    }

    .brand-mark {
      height: 40px;
    }

    .brand-divider {
      height: 46px;
    }

    .brand-copy strong {
      font-size: 0.82rem;
    }

    .dropdown {
      box-shadow: none;
      min-width: 100%;
      position: static;
      transform: none;
      width: 100%;
    }
  }
</style>
