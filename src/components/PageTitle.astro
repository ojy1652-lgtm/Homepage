---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="page-title">
  <div class="container">
    <h1>{title}</h1>
  </div>
</header>

<style>
  .page-title {
    padding: 34px 0 0;
  }

  .page-title .container {
    border-bottom: 1px solid var(--line);
    padding-bottom: 18px;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3rem);
  }
</style>
