---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Research Lab',
  description = 'Academic research laboratory homepage',
} = Astro.props;

const pageTitle = title === 'Research Lab' ? title : `${title} | Research Lab`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      if (window.netlifyIdentity) {
        const hash = window.location.hash || '';
        const hasInviteToken = hash.includes('invite_token=');
        const hasRecoveryToken = hash.includes('recovery_token=');

        window.netlifyIdentity.on('init', (user) => {
          if (!user && hasInviteToken) {
            window.netlifyIdentity.open('signup');
          }

          if (!user && hasRecoveryToken) {
            window.netlifyIdentity.open('recovery');
          }

          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #151515;
    --muted: #626262;
    --line: #dedede;
    --soft: #f7f7f7;
    --paper: #ffffff;
    --brand: #073a78;
    --brand-2: #007fc4;
    --accent: #26b5df;
    --link: #073a78;
    --deep: #101010;
    --max: 1180px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.6;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  p {
    margin: 0 0 1rem;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    line-height: 1.15;
    letter-spacing: 0;
  }

  .container {
    width: min(100% - 32px, var(--max));
    margin-inline: auto;
  }

  .section {
    padding: 72px 0;
  }

  .page-title + .section {
    padding-top: 36px;
  }

  .section.alt {
    background: var(--soft);
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  .page-head {
    padding: 72px 0 44px;
    background: linear-gradient(180deg, #eef4f5 0%, #fff 100%);
    border-bottom: 1px solid var(--line);
  }

  .page-head h1 {
    font-size: clamp(2rem, 5vw, 4.25rem);
    max-width: 880px;
  }

  .page-head p {
    color: var(--muted);
    font-size: 1.08rem;
    max-width: 760px;
    margin-top: 18px;
  }

  .grid {
    display: grid;
    gap: 22px;
  }

  .grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: clip;
  }

  .card-body {
    padding: 22px;
  }

  .card h2,
  .card h3 {
    font-size: 1.25rem;
  }

  .card p {
    color: var(--muted);
    margin-top: 10px;
  }

  .meta {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .button {
    align-items: center;
    background: var(--brand);
    border: 1px solid var(--brand);
    border-radius: 6px;
    color: #fff;
    display: inline-flex;
    font-weight: 700;
    min-height: 44px;
    padding: 0 16px;
  }

  .button.secondary {
    background: transparent;
    color: var(--brand);
  }

  .prose {
    color: #263844;
    font-size: 1.03rem;
    max-width: 840px;
  }

  .prose h2 {
    font-size: 1.65rem;
    margin: 2rem 0 0.75rem;
  }

  .prose ul {
    padding-left: 1.2rem;
  }

  @media (max-width: 820px) {
    .section {
      padding: 52px 0;
    }

    .grid.two,
    .grid.three {
      grid-template-columns: 1fr;
    }
  }
</style>
