---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import PersonCard from '@/components/PersonCard.astro';

const entries = await getCollection('people');
const people = await Promise.all(
  entries
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (person) => ({ ...person, rendered: await person.render() }))
);

const peopleGroups = [
  {
    id: 'principal-investigator',
    title: 'Principal Investigator',
    description: '연구실을 이끄는 책임 연구자입니다.',
    items: people.filter((person) => person.data.category === 'principal-investigator'),
  },
  {
    id: 'researcher',
    title: 'Researcher',
    description: '현재 연구 프로젝트를 수행하는 연구원과 학생입니다.',
    items: people.filter((person) => person.data.category === 'researcher'),
  },
  {
    id: 'alumni',
    title: 'Alumni',
    description: '연구실을 거쳐 간 졸업생과 이전 구성원입니다.',
    items: people.filter((person) => person.data.category === 'alumni' || person.data.alumni),
  },
  {
    id: 'collaborators',
    title: 'Collaborators',
    description: '공동 연구를 함께 진행하는 외부 협력 연구자입니다.',
    items: people.filter((person) => person.data.category === 'collaborator'),
  },
];
---

<BaseLayout title="People" description="Research lab members">
  <PageHeader
    eyebrow="People"
    title="People"
    description="교수, 연구원, 학생, 졸업생 정보를 관리합니다. 사진은 CMS 업로드 폴더에서 불러옵니다."
  />
  <section class="section">
    <div class="container people-sections">
      {
        peopleGroups.map((group) => (
          <section class="people-group" id={group.id}>
            <div class="group-head">
              <p class="eyebrow">People</p>
              <h2>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            {
              group.items.length > 0 ? (
                <div class="people-grid">
                  {group.items.map((person) => {
                    const Content = person.rendered.Content;
                    return (
                      <PersonCard
                        name={person.data.name}
                        role={person.data.role}
                        group={person.data.group}
                        email={person.data.email}
                        website={person.data.website}
                        photo={person.data.photo}
                        education={person.data.education}
                        Content={Content}
                      />
                    );
                  })}
                </div>
              ) : (
                <p class="empty-state">No members listed yet.</p>
              )
            }
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .people-sections {
    display: grid;
    gap: 58px;
  }

  .people-group {
    scroll-margin-top: 110px;
  }

  .group-head {
    margin-bottom: 20px;
    max-width: 760px;
  }

  .group-head h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .group-head p:not(.eyebrow) {
    color: var(--muted);
    margin-top: 10px;
  }

  .people-grid {
    display: grid;
    gap: 18px;
  }

  .empty-state {
    border: 1px dashed var(--line);
    border-radius: 8px;
    color: var(--muted);
    margin: 0;
    padding: 20px;
  }
</style>
