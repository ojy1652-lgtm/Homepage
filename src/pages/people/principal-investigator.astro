---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageTitle from '@/components/PageTitle.astro';

const profiles = await getCollection('pi');
const profile = profiles[0];
---

<BaseLayout title="Principal Investigator" description="Principal investigator profile">
  <PageTitle title="Principal Investigator" />
  <section class="section">
    <div class="container">
      {
        profile ? (
          <article class="pi-profile">
            <div class="pi-hero">
              <div class="pi-photo-wrap">
                <img src={profile.data.photo} alt={`${profile.data.name} profile`} />
              </div>
              <div class="pi-copy">
                <p class="role">{profile.data.label}</p>
                <h2>{profile.data.name}</h2>
                <p class="position">{profile.data.department}</p>
                <p class="position">
                  {profile.data.institution}, {profile.data.location}
                </p>
                <div class="pi-links">
                  <a href={`mailto:${profile.data.email}`}>{profile.data.email}</a>
                  {profile.data.scholarUrl && (
                    <a href={profile.data.scholarUrl} target="_blank" rel="noreferrer">Google Scholar</a>
                  )}
                </div>
                {
                  profile.data.education.length > 0 && (
                    <section class="education" aria-label={`${profile.data.name} education`}>
                      <h3>Education</h3>
                      <ul>
                        {profile.data.education.map((item) => <li>{item}</li>)}
                      </ul>
                    </section>
                  )
                }
              </div>
            </div>

            {
              profile.data.researchExperience.length > 0 && (
                <section class="pi-section">
                  <h2>Research Experience</h2>
                  <div class="experience-list">
                    {profile.data.researchExperience.map((item) => (
                      <article class="experience-item">
                        <h3>
                          {item.position} <span>({item.period})</span>
                        </h3>
                        <p>{item.affiliation}</p>
                      </article>
                    ))}
                  </div>
                </section>
              )
            }

            {
              profile.data.representativePublications.length > 0 && (
                <section class="pi-section">
                  <h2>Representative Publications</h2>
                  <ol class="publication-list">
                    {profile.data.representativePublications.map((publication) => <li>{publication}</li>)}
                  </ol>
                </section>
              )
            }
          </article>
        ) : (
          <p class="empty-state">No principal investigator profile listed yet.</p>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .pi-profile {
    display: grid;
    gap: 56px;
  }

  .pi-hero {
    align-items: center;
    display: grid;
    gap: 42px;
    grid-template-columns: minmax(260px, 0.45fr) minmax(0, 0.55fr);
  }

  .pi-photo-wrap {
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 16px;
  }

  .pi-photo-wrap img {
    aspect-ratio: 4 / 5;
    border-radius: 6px;
    object-fit: cover;
    width: 100%;
  }

  .pi-copy {
    align-self: center;
  }

  .role {
    color: var(--brand);
    font-size: 0.86rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  .pi-copy h2 {
    font-size: clamp(2.2rem, 5vw, 4rem);
  }

  .position {
    color: var(--muted);
    font-size: 1.12rem;
    margin: 8px 0 0;
  }

  .pi-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 22px 0;
  }

  .pi-links a {
    color: var(--link);
    font-weight: 800;
  }

  .education {
    border-left: 4px solid var(--accent);
    margin-top: 24px;
    padding-left: 18px;
  }

  .education h3 {
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  .pi-section h2 {
    font-size: 1.28rem;
    letter-spacing: 0.04em;
    margin: 0 0 16px;
    text-transform: uppercase;
  }

  .education ul {
    color: var(--muted);
    display: grid;
    gap: 6px;
    margin: 0;
    padding-left: 1.1rem;
  }

  .pi-section {
    border-top: 1px solid var(--line);
    padding-top: 34px;
  }

  .experience-list {
    display: grid;
    gap: 18px;
  }

  .experience-item h3 {
    font-size: 1.08rem;
  }

  .experience-item h3 span {
    color: var(--muted);
    font-weight: 700;
  }

  .experience-item p {
    color: var(--muted);
    margin: 6px 0 0;
  }

  .publication-list {
    color: var(--muted);
    display: grid;
    gap: 14px;
    margin: 0;
    padding-left: 1.3rem;
  }

  .publication-list li::marker {
    color: var(--brand);
    font-weight: 900;
  }

  .empty-state {
    border: 1px dashed var(--line);
    border-radius: 8px;
    color: var(--muted);
    margin: 0;
    padding: 20px;
  }

  @media (max-width: 820px) {
    .pi-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
