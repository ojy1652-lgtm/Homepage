---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageTitle from '@/components/PageTitle.astro';

const papers = (await getCollection('publications')).sort(
  (a, b) => b.data.year - a.data.year || a.data.order - b.data.order || a.data.title.localeCompare(b.data.title)
);
const years = [...new Set(papers.map((paper) => paper.data.year))];

function normalizeAuthor(author: string | { name: string; labMember?: boolean; corresponding?: boolean }) {
  if (typeof author === 'string') {
    return { name: author, labMember: false, corresponding: false };
  }

  return {
    name: author.name,
    labMember: Boolean(author.labMember),
    corresponding: Boolean(author.corresponding),
  };
}

function getSearchText(paper: (typeof papers)[number]) {
  const authors = paper.data.authors.map(normalizeAuthor).map((author) => author.name).join(' ');
  return [
    paper.data.title,
    authors,
    paper.data.journal,
    paper.data.year,
    paper.data.volume,
    paper.data.pages,
    paper.data.doi,
    paper.data.tags.join(' '),
  ]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();
}

function getCitation(paper: (typeof papers)[number]) {
  return [paper.data.journal, paper.data.volume, paper.data.pages].filter(Boolean).join(', ');
}
---

<BaseLayout title="Publications" description="Publication list">
  <PageTitle title="Publications" />
  <section class="section">
    <div class="container">
      <div class="publication-toolbar">
        <input id="publication-search" data-publication-search type="search" placeholder="Search title, author, journal..." />
      </div>
      <div class="publication-years" data-publication-years>
      {
        years.map((year) => (
          <section class="year-block" data-publication-year>
            <h2>{year}</h2>
            <div class="paper-list">
              {
                papers
                  .filter((paper) => paper.data.year === year)
                  .map((paper) => {
                    const authors = paper.data.authors.map(normalizeAuthor);
                    return (
                      <article
                        class:list={['paper', paper.data.featured ? 'featured' : '']}
                        data-publication
                        data-search={getSearchText(paper)}
                      >
                        <h3>{paper.data.title}</h3>
                        <p class="authors">
                          {authors.map((author, index) => (
                            <>
                              {index > 0 && <span>, </span>}
                              <span class:list={['author', author.labMember ? 'lab-member' : '']}>
                                {author.name}
                                {author.corresponding && <sup>*</sup>}
                              </span>
                            </>
                          ))}
                        </p>
                        <p class="meta">
                          {getCitation(paper)}
                        </p>
                        {paper.data.doi && (
                          <div class="paper-links">
                            <a href={`https://doi.org/${paper.data.doi}`}>DOI</a>
                          </div>
                        )}
                      </article>
                    );
                  })
              }
            </div>
          </section>
        ))
      }
      </div>
      <p class="empty-state" data-publication-empty hidden>No publications found.</p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const searchInput = document.querySelector('[data-publication-search]');
  const publications = Array.from(document.querySelectorAll('[data-publication]'));
  const yearBlocks = Array.from(document.querySelectorAll('[data-publication-year]'));
  const emptyState = document.querySelector('[data-publication-empty]');

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      publications.forEach((publication) => {
        const matches = !query || publication.dataset.search.includes(query);
        publication.hidden = !matches;
        if (matches) visibleCount += 1;
      });

      yearBlocks.forEach((block) => {
        const hasVisiblePublication = Array.from(block.querySelectorAll('[data-publication]')).some(
          (publication) => !publication.hidden
        );
        block.hidden = !hasVisiblePublication;
      });

      if (emptyState) {
        emptyState.hidden = visibleCount > 0;
      }
    });
  }
</script>

<style>
  .publication-toolbar {
    align-items: end;
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-bottom: 28px;
  }

  .publication-toolbar label {
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .publication-toolbar input {
    border: 1px solid var(--line);
    border-radius: 6px;
    font: inherit;
    min-height: 42px;
    padding: 8px 12px;
    width: min(100%, 360px);
  }

  .publication-toolbar input:focus {
    border-color: var(--brand);
    outline: none;
  }

  .publication-years {
    display: grid;
    gap: 42px;
  }

  .year-block {
    display: grid;
    gap: 18px;
    grid-template-columns: 110px minmax(0, 1fr);
  }

  .year-block h2 {
    color: var(--brand);
    font-size: 1.55rem;
  }

  .paper-list {
    display: grid;
    gap: 14px;
  }

  .paper {
    border: 1px solid var(--line);
    border-left: 5px solid var(--line);
    border-radius: 8px;
    padding: 20px;
  }

  .paper.featured {
    border-left-color: var(--accent);
  }

  .paper h3 {
    font-size: 1.15rem;
  }

  .paper p {
    color: var(--muted);
    margin: 8px 0 0;
  }

  .authors {
    color: var(--muted);
  }

  .author.lab-member {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
  }

  .author sup {
    color: var(--brand-2);
    font-size: 0.75em;
    font-weight: 900;
    margin-left: 1px;
  }

  .paper-links {
    display: flex;
    gap: 12px;
    margin-top: 12px;
  }

  .paper-links a {
    color: var(--link);
    font-weight: 800;
  }

  .empty-state {
    border: 1px dashed var(--line);
    border-radius: 8px;
    color: var(--muted);
    margin: 0;
    padding: 20px;
  }

  @media (max-width: 700px) {
    .publication-toolbar {
      align-items: stretch;
      flex-direction: column;
    }

    .publication-toolbar input {
      width: 100%;
    }

    .year-block {
      grid-template-columns: 1fr;
    }
  }
</style>
